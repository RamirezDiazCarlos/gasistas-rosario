---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import QuickAnswer from '../components/QuickAnswer.astro';
import SearchFilter from '../components/SearchFilter.astro';
import GasistaGrid from '../components/GasistaGrid.astro';
import ZoneSections from '../components/ZoneSections.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import ListYourself from '../components/ListYourself.astro';
import Footer from '../components/Footer.astro';
import gasistas from '../data/gasistas.json';

const FAQ_ITEMS = [
  {
    q: "¿Cómo encuentro un gasista matriculado en Rosario?",
    a: "En GasistasRosario.com.ar encontrás un directorio de gasistas matriculados habilitados por Litoral Gas. Podés filtrar por zona (centro, Fisherton, Pichincha, Echesortu, entre otros barrios) y por servicio (instalación, reparación, certificado, urgencias). Cada profesional tiene su matrícula verificada y se contacta directo por WhatsApp, sin intermediarios ni comisiones.",
  },
  {
    q: "¿Cómo verificar si un gasista está matriculado?",
    a: "Ingresá al listado oficial de Litoral Gas (litoral-gas.com.ar/site/hogares-y-comercios/info-y-tramites/listado-de-gasistas-y-profesionales), seleccioná tu localidad y buscá al profesional por nombre. Si aparece en el listado, está matriculado. Todos los gasistas matriculados cuentan con una credencial con foto emitida por la distribuidora que acredita su identidad y categoría habilitada.",
  },
  {
    q: "¿Qué diferencia hay entre gasista M1, M2 y M3?",
    a: "Son las tres categorías de matriculación según ENARGAS. M1 (Primera Categoría) es la más alta: accesible a ingenieros, arquitectos y MMO, habilita instalaciones domiciliarias, comerciales e industriales hasta 150.000 Kcal/h. M2 (Segunda Categoría) habilita hasta 300.000 Kcal/h en edificios y comercios. M3 (Tercera Categoría) habilita unidades unifuncionales (casas y departamentos individuales).",
  },
  {
    q: "¿Cuándo necesito contratar un gasista matriculado?",
    a: "Siempre que se trabaje sobre una instalación de gas. Es obligatorio para nuevas instalaciones, reparaciones, detección de pérdidas, habilitación comercial, certificados para inmobiliarias o escribanías, rehabilitación de servicio cortado y planos. La Ley 24.076 y la normativa NAG-200 de ENARGAS establecen que solo un gasista matriculado puede intervenir legalmente en instalaciones de gas.",
  },
  {
    q: "¿Qué hago si tengo una urgencia de gas en Rosario?",
    a: "Si sentís olor a gas o sospechás una fuga, ventilá el ambiente, cerrá la llave de paso general, no enciendas luces ni aparatos eléctricos y llamá al 0800-777-5427 de Litoral Gas, disponible las 24 horas. Para reparaciones no urgentes, en GasistasRosario.com.ar podés filtrar profesionales que ofrecen atención 24hs en tu zona.",
  },
  {
    q: "¿Qué servicios hace un gasista matriculado?",
    a: "Un gasista matriculado realiza instalación de cañerías y artefactos, reparación de pérdidas, detección con equipamiento electrónico, certificados de aptitud para inmobiliarias y escribanías, habilitación comercial, instalación y mantenimiento de calderas, rehabilitación de servicio cortado, planos y cálculos para aprobación de obra. Solo él puede intervenir legalmente en instalaciones de gas.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": FAQ_ITEMS.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a,
    },
  })),
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Gasistas matriculados en Rosario, Santa Fe",
  "description": "Directorio de gasistas matriculados y verificados en el Gran Rosario",
  "url": "https://gasistasrosario.com.ar",
  "numberOfItems": gasistas.length,
  "itemListElement": gasistas.map((g, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": `${g.name} — Gasista Matriculado/a en Rosario`,
      "url": `https://gasistasrosario.com.ar/${g.slug}`,
      ...(g.phone ? { "telephone": `+${g.phone}` } : {}),
      "identifier": g.matricula,
      "areaServed": g.zones.map(z => ({ "@type": "Place", "name": `${z}, Santa Fe, Argentina` })),
    },
  })),
};
---

<Layout
  title="Gasistas Matriculados en Rosario | GasistasRosario"
  description="Encontrá gasistas matriculados y verificados en Rosario, Santa Fe. Instalaciones, reparaciones, certificados de gas y urgencias. Contactalos directo por WhatsApp."
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListSchema)} />
  </Fragment>

  <Header />
  <main id="main-content">
    <Hero />
    <QuickAnswer />
    <div>
      <SearchFilter />
      <GasistaGrid />
    </div>
    <ZoneSections />
    <Testimonials />
    <FAQ questions={FAQ_ITEMS} />
    <ListYourself />
  </main>
  <Footer />
</Layout>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  /* Account for floating pill header (≈76px) + filter bar (≈48px) */
  #profesionales {
    scroll-margin-top: 76px;
  }
  #como-funciona {
    scroll-margin-top: 76px;
  }
  #listar {
    scroll-margin-top: 76px;
  }

  /* Scroll reveal */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(16px);
    filter: blur(2px);
    transition:
      opacity 0.7s cubic-bezier(0.32, 0.72, 0, 1),
      transform 0.7s cubic-bezier(0.32, 0.72, 0, 1),
      filter 0.7s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .scroll-reveal.visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  /* Staggered children */
  .stagger-children > * {
    opacity: 0;
    transform: translateY(16px);
    filter: blur(2px);
    transition:
      opacity 0.6s cubic-bezier(0.32, 0.72, 0, 1),
      transform 0.6s cubic-bezier(0.32, 0.72, 0, 1),
      filter 0.5s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .stagger-children.visible > * { opacity:1; transform:translateY(0); filter:blur(0); }
  .stagger-children.visible > *:nth-child(1) { transition-delay: 0ms; }
  .stagger-children.visible > *:nth-child(2) { transition-delay: 80ms; }
  .stagger-children.visible > *:nth-child(3) { transition-delay: 160ms; }
  .stagger-children.visible > *:nth-child(4) { transition-delay: 240ms; }
  .stagger-children.visible > *:nth-child(5) { transition-delay: 320ms; }
  .stagger-children.visible > *:nth-child(6) { transition-delay: 400ms; }
  .stagger-children.visible > *:nth-child(n+7) { transition-delay: 480ms; }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -32px 0px' }
  );

  document.querySelectorAll('.scroll-reveal, .stagger-children').forEach(el => observer.observe(el));
</script>
