---
import gasistas from '../data/gasistas.json';
import GasistaCard from './GasistaCard.astro';

const sorted = [...gasistas].sort((a, b) => {
  if (a.featured && !b.featured) return -1;
  if (!a.featured && b.featured) return 1;
  return b.rating - a.rating;
});
---

<section id="profesionales" class="py-20 sm:py-24 bg-warm-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12 scroll-reveal">
      <div>
        <p class="text-[10px] font-semibold text-flame/70 uppercase tracking-[0.2em] mb-3">
          Profesionales habilitados
        </p>
        <h2 class="font-display font-800 text-dark text-3xl sm:text-4xl lg:text-5xl tracking-tight leading-tight">
          Encontrá el tuyo.
        </h2>
      </div>
      <p class="text-warm-800/60 text-sm max-w-[220px] leading-relaxed sm:text-right pb-1">
        Matrícula y zonas en cada perfil. Contacto directo por WhatsApp.
      </p>
    </div>

    <div id="gasista-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4 stagger-children">
      {sorted.map(gasista => (
        <div
          data-card
          data-zones={gasista.zones.join(',')}
          data-services={gasista.services.join(',')}
        >
          <GasistaCard gasista={gasista} />
        </div>
      ))}
    </div>

    <!-- sin resultados -->
    <div id="no-results" class="hidden">
      <div class="py-20 flex flex-col items-center text-center">
        <div class="w-12 h-12 rounded-2xl bg-warm-100 border border-warm-200 flex items-center justify-center mb-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" class="text-warm-800/50" aria-hidden="true">
            <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/>
            <path d="M14 14L18 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M7 9H11M9 7V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <p class="font-display font-700 text-dark text-base mb-1">Sin resultados</p>
        <p class="text-warm-800/60 text-sm max-w-xs">Probá con otros filtros o limpiá la búsqueda.</p>
      </div>
    </div>

  </div>
</section>

<section id="como-funciona" class="py-24 sm:py-32 bg-[#1a1612] overflow-hidden relative">

  <!-- glow decorativo -->
  <div class="absolute right-0 top-1/2 -translate-y-1/2 w-[600px] h-[600px] pointer-events-none" aria-hidden="true"
    style="background: radial-gradient(circle, rgba(224,116,24,0.07) 0%, transparent 65%);">
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

    <div class="mb-16 scroll-reveal">
      <p class="text-[10px] font-semibold text-flame/60 uppercase tracking-[0.2em] mb-3">
        Sin intermediarios
      </p>
      <h2 class="font-display font-800 text-white text-3xl sm:text-4xl lg:text-5xl tracking-tight leading-tight mb-3">
        Tres pasos,<br/> sin vueltas.
      </h2>
      <p class="text-white/30 text-sm leading-relaxed">
        Sin registros. Sin comisiones. Solo contacto directo.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-0 rounded-2xl overflow-hidden stagger-children">

      {[
        {
          n: "01",
          title: "Filtrá por zona o servicio",
          body: "Elegí el barrio que necesitás y el tipo de trabajo que querés hacer.",
        },
        {
          n: "02",
          title: "Revisá el perfil",
          body: "Verificá matrícula, zonas, calificaciones y descripción del profesional.",
        },
        {
          n: "03",
          title: "Contactá por WhatsApp",
          body: "Directo con el gasista, sin comisiones ni formularios.",
        },
      ].map(({ n, title, body }) => (
        <div class="relative flex flex-col gap-6 p-8 lg:p-10 bg-[#1a1612] hover:bg-white/[0.04] transition-colors duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]">
          <div class="relative w-fit">
            <span
              class="font-display font-800 text-[96px] leading-none tracking-[-0.04em] select-none"
              style="color: transparent; -webkit-text-stroke: 1px rgba(224,116,24,0.18);"
              aria-hidden="true"
            >
              {n}
            </span>
            <span class="absolute bottom-2 left-1 w-1.5 h-1.5 rounded-full bg-flame/70 inline-block"></span>
          </div>

          <div>
            <h3 class="font-display font-700 text-white text-base mb-2.5">{title}</h3>
            <p class="text-white/35 text-sm leading-relaxed max-w-[220px]">{body}</p>
          </div>
        </div>
      ))}

    </div>
  </div>
</section>
