---
import gasistas from '../data/gasistas.json';

const ZONES: Record<string, string[]> = {
  "Centro":      ["Centro", "Pichincha", "Abasto", "Echesortu", "Barrio Martín", "República de la Sexta", "Lourdes", "Terminal / Agote"],
  "Norte":       ["Alberdi", "Arroyito", "Refinería", "Sarmiento", "La Florida", "Parque Field", "Rucci", "Lomas de Alberdi"],
  "Noroeste":    ["Fisherton", "Belgrano", "Azcuénaga", "Empalme Granero", "Ludueña", "Hostal del Sol", "Aldea", "San Eduardo"],
  "Sur":         ["Saladillo", "Tiro Suizo", "Tablada", "España y Hospitales", "Las Heras", "Acindar"],
  "Oeste":       ["Bella Vista", "Cinco Esquinas", "Barrio Godoy", "Barrio Alvear", "Vía Honda"],
  "Alrededores": ["Funes", "Roldán", "Villa Gobernador Gálvez", "Alvear"],
};

const allServices = [...new Set(gasistas.flatMap((g: any) => g.services))].sort((a: any, b: any) => a.localeCompare(b, 'es'));
const total = gasistas.length;
const zoneEntries = Object.entries(ZONES);
---

<div class="sticky top-[68px] z-40 pointer-events-none">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-3 pointer-events-auto">
    <div class="bg-white/96 backdrop-blur-2xl border border-warm-200/60 rounded-2xl shadow-[0_4px_24px_-8px_rgba(0,0,0,0.08),0_1px_2px_rgba(0,0,0,0.04)] px-3 sm:px-4">
      <div class="flex items-center gap-1.5 sm:gap-2 py-2.5">

        <div class="relative" id="zone-wrapper">
          <button
            type="button"
            id="zone-trigger"
            aria-haspopup="true"
            aria-expanded="false"
            class="filter-trigger flex items-center gap-1.5 px-3 py-1.5 rounded-xl border border-warm-200/80 bg-warm-50/70 text-[12px] font-medium text-warm-700 hover:bg-warm-100 hover:border-warm-300/60 transition-all duration-200"
          >
            <svg width="12" height="12" viewBox="0 0 13 13" fill="none" class="text-warm-500 flex-shrink-0" aria-hidden="true">
              <path d="M6.5 1C4.567 1 3 2.567 3 4.5C3 7.5 6.5 12 6.5 12C6.5 12 10 7.5 10 4.5C10 2.567 8.433 1 6.5 1Z" stroke="currentColor" stroke-width="1.3"/>
              <circle cx="6.5" cy="4.5" r="1.4" fill="currentColor"/>
            </svg>
            <span id="zone-label">Zona</span>
            <svg width="8" height="5" viewBox="0 0 9 5" fill="none" class="trigger-chevron text-warm-400 transition-transform duration-200 flex-shrink-0" aria-hidden="true">
              <path d="M1 1L4.5 4L8 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div
            id="zone-panel"
            class="filter-panel hidden absolute top-[calc(100%+8px)] left-0 z-50 w-96 max-w-[calc(100vw-32px)] bg-white border border-warm-200/80 rounded-2xl shadow-[0_8px_32px_-4px_rgba(0,0,0,0.12),0_2px_8px_-2px_rgba(0,0,0,0.06)] overflow-hidden"
          >
            <div class="px-3 pt-3 pb-2">
              <button
                type="button"
                id="zone-opt-todo"
                data-value="__todo_rosario__"
                class="zone-option w-full flex items-center gap-2 px-3 py-2 rounded-xl text-xs font-medium text-warm-600 hover:bg-warm-50 hover:text-warm-900 transition-all duration-150 text-left"
              >
                <svg width="11" height="11" viewBox="0 0 13 13" fill="none" class="flex-shrink-0 text-flame">
                  <path d="M6.5 1C4.567 1 3 2.567 3 4.5C3 7.5 6.5 12 6.5 12C6.5 12 10 7.5 10 4.5C10 2.567 8.433 1 6.5 1Z" stroke="currentColor" stroke-width="1.3"/>
                  <circle cx="6.5" cy="4.5" r="1.4" fill="currentColor"/>
                </svg>
                Todo Rosario
              </button>
            </div>

            <div class="h-px bg-warm-100 mx-3"></div>

            <div class="flex gap-0.5 px-3 pt-2.5 overflow-x-auto scrollbar-none" role="tablist">
              {zoneEntries.map(([group], i) => (
                <button
                  type="button"
                  role="tab"
                  class="zone-tab-btn flex-shrink-0 px-2 py-1 text-[10px] font-semibold rounded-lg transition-all duration-150 whitespace-nowrap"
                  data-group={group}
                  aria-selected={i === 0 ? "true" : "false"}
                >
                  {group}
                </button>
              ))}
            </div>

            <div class="px-3 pt-2 pb-3">
              {zoneEntries.map(([group, barrios], i) => (
                <div
                  class="zone-barrios-panel flex flex-wrap gap-1"
                  data-group={group}
                  style={i !== 0 ? "display:none" : ""}
                >
                  {barrios.map((b: string) => (
                    <button
                      type="button"
                      class="zone-option barrio-opt px-2 py-0.5 rounded-md border border-warm-200 text-warm-600 text-[11px] font-medium transition-all duration-150 hover:border-warm-300 hover:text-warm-900 hover:bg-warm-50"
                      data-value={b}
                    >
                      {b}
                    </button>
                  ))}
                </div>
              ))}
            </div>

            <div class="border-t border-warm-100 px-3 py-2">
              <button type="button" id="zone-clear" class="text-[10px] text-warm-400 hover:text-flame transition-colors duration-150 font-medium">
                Ver todas las zonas
              </button>
            </div>
          </div>
        </div>

        <div class="hidden sm:block w-px h-3.5 bg-warm-200/80 flex-shrink-0" aria-hidden="true"></div>

        <div class="relative" id="service-wrapper">
          <button
            type="button"
            id="service-trigger"
            aria-haspopup="true"
            aria-expanded="false"
            class="filter-trigger flex items-center gap-1.5 px-3 py-1.5 rounded-xl border border-warm-200/80 bg-warm-50/70 text-[12px] font-medium text-warm-700 hover:bg-warm-100 hover:border-warm-300/60 transition-all duration-200"
          >
            <svg width="12" height="12" viewBox="0 0 13 13" fill="none" class="text-warm-500 flex-shrink-0" aria-hidden="true">
              <path d="M2 10L4.5 7.5L2 5L4.5 2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M7 2.5H11M7 6.5H11M7 10.5H9.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
            <span id="service-label">Servicio</span>
            <svg width="8" height="5" viewBox="0 0 9 5" fill="none" class="trigger-chevron text-warm-400 transition-transform duration-200 flex-shrink-0" aria-hidden="true">
              <path d="M1 1L4.5 4L8 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div
            id="service-panel"
            class="filter-panel hidden absolute top-[calc(100%+8px)] left-0 z-50 w-72 max-w-[calc(100vw-32px)] bg-white border border-warm-200/80 rounded-2xl shadow-[0_8px_32px_-4px_rgba(0,0,0,0.12),0_2px_8px_-2px_rgba(0,0,0,0.06)] py-2 overflow-hidden"
          >
            {allServices.map((s: any) => (
              <button
                type="button"
                class="service-option w-full flex items-center justify-between px-4 py-1.5 text-xs font-medium text-warm-600 hover:bg-warm-50 hover:text-warm-900 transition-all duration-150 text-left"
                data-value={s}
              >
                {s}
                <svg class="service-check hidden w-3 h-3 text-flame flex-shrink-0" viewBox="0 0 12 12" fill="none">
                  <path d="M2 6L5 9L10 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            ))}
            <div class="border-t border-warm-100 mt-1 pt-1 px-2">
              <button type="button" id="service-clear" class="w-full text-left text-[10px] text-warm-400 hover:text-flame transition-colors duration-150 font-medium px-2 py-1">
                Ver todos los servicios
              </button>
            </div>
          </div>
        </div>

        <div class="ml-auto flex items-center gap-2.5">
          <p id="result-count" class="text-[12px] text-warm-700/70">
            <span id="count-number" class="font-semibold text-warm-900/80">{total}</span>
            <span id="count-label"> profesionales</span>
          </p>
          <button
            id="reset-filters"
            class="hidden items-center gap-1 text-[11px] text-flame hover:text-flame-dark font-semibold transition-colors duration-200"
            aria-label="Limpiar filtros"
          >
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <path d="M1 1L9 9M9 1L1 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Limpiar
          </button>
        </div>

      </div>
    </div>
  </div>
</div>

<style>
  .filter-trigger.is-active {
    background: rgba(224, 116, 24, 0.08);
    border-color: rgba(224, 116, 24, 0.25);
    color: #b85c12;
  }
  .filter-trigger.is-active svg { color: #e07418; }
  .filter-trigger[aria-expanded="true"] .trigger-chevron { transform: rotate(180deg); }

  .zone-tab-btn { color: #a8967e; background: transparent; }
  .zone-tab-btn:hover { color: #3d322b; background: #f8f5f1; }
  .zone-tab-btn[aria-selected="true"] { color: #b85c12; background: rgba(224,116,24,0.10); }

  .barrio-opt.selected { background: rgba(224,116,24,0.10); border-color: rgba(224,116,24,0.35); color: #b85c12; }

  .service-option.selected { color: #3d322b; background: #f8f5f1; }
  .service-option.selected .service-check { display: block; }

  #zone-opt-todo.selected { background: rgba(224,116,24,0.08); color: #b85c12; }

  .scrollbar-none { scrollbar-width: none; }
  .scrollbar-none::-webkit-scrollbar { display: none; }
</style>

<script>
  const ZONES_DATA: Record<string, string[]> = {
    "Centro":      ["Centro","Pichincha","Abasto","Echesortu","Barrio Martín","República de la Sexta","Lourdes","Terminal / Agote"],
    "Norte":       ["Alberdi","Arroyito","Refinería","Sarmiento","La Florida","Parque Field","Rucci","Lomas de Alberdi"],
    "Noroeste":    ["Fisherton","Belgrano","Azcuénaga","Empalme Granero","Ludueña","Hostal del Sol","Aldea","San Eduardo"],
    "Sur":         ["Saladillo","Tiro Suizo","Tablada","España y Hospitales","Las Heras","Acindar"],
    "Oeste":       ["Bella Vista","Cinco Esquinas","Barrio Godoy","Barrio Alvear","Vía Honda"],
    "Alrededores": ["Funes","Roldán","Villa Gobernador Gálvez","Alvear"],
  };

  const ROSARIO_ZONES = new Set(Object.values(ZONES_DATA).flat());

  const zoneTrigger   = document.getElementById('zone-trigger') as HTMLButtonElement;
  const zonePanel     = document.getElementById('zone-panel')!;
  const zoneLabel     = document.getElementById('zone-label')!;
  const zoneTabBtns   = document.querySelectorAll<HTMLButtonElement>('.zone-tab-btn');
  const barriosPanels = document.querySelectorAll<HTMLElement>('.zone-barrios-panel');
  const barrioOpts    = document.querySelectorAll<HTMLButtonElement>('.barrio-opt');
  const zoneTodo      = document.getElementById('zone-opt-todo') as HTMLButtonElement;
  const zoneClear     = document.getElementById('zone-clear') as HTMLButtonElement;
  const serviceTrigger= document.getElementById('service-trigger') as HTMLButtonElement;
  const servicePanel  = document.getElementById('service-panel')!;
  const serviceLabel  = document.getElementById('service-label')!;
  const serviceOpts   = document.querySelectorAll<HTMLButtonElement>('.service-option');
  const serviceClear  = document.getElementById('service-clear') as HTMLButtonElement;
  const resetBtn      = document.getElementById('reset-filters') as HTMLButtonElement;
  const countNumber   = document.getElementById('count-number')!;
  const countLabel    = document.getElementById('count-label')!;
  const noResults     = document.getElementById('no-results');

  let activeZone    = '';
  let activeService = '';

  const closeAll = () => {
    [zonePanel, servicePanel].forEach(p => p.classList.add('hidden'));
    [zoneTrigger, serviceTrigger].forEach(t => t.setAttribute('aria-expanded', 'false'));
  };

  const togglePanel = (trigger: HTMLButtonElement, panel: HTMLElement) => {
    const isOpen = trigger.getAttribute('aria-expanded') === 'true';
    closeAll();
    if (!isOpen) { panel.classList.remove('hidden'); trigger.setAttribute('aria-expanded', 'true'); }
  };

  zoneTrigger.addEventListener('click', (e) => { e.stopPropagation(); togglePanel(zoneTrigger, zonePanel); });
  serviceTrigger.addEventListener('click', (e) => { e.stopPropagation(); togglePanel(serviceTrigger, servicePanel); });
  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('#zone-wrapper') && !(e.target as HTMLElement).closest('#service-wrapper')) closeAll();
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAll(); });

  zoneTabBtns.forEach(tab => {
    tab.addEventListener('click', () => {
      const g = tab.dataset.group!;
      zoneTabBtns.forEach(t => t.setAttribute('aria-selected', String(t.dataset.group === g)));
      barriosPanels.forEach(p => { p.style.display = p.dataset.group === g ? '' : 'none'; });
    });
  });

  const updateCount = (n: number) => {
    countNumber.textContent = String(n);
    countLabel.textContent  = n === 1 ? ' profesional' : ' profesionales';
  };

  const scrollToGrid = () => {
    const filterEl = document.getElementById('zone-wrapper')?.closest('.sticky');
    const filterBottom = filterEl ? filterEl.getBoundingClientRect().bottom : 120;
    if (window.scrollY > filterBottom + 100) {
      const grid = document.querySelector('[data-card]')?.closest('section') ?? document.body;
      const offset = (filterEl?.getBoundingClientRect().height ?? 60) + 12;
      const top = (grid as HTMLElement).getBoundingClientRect().top + window.scrollY - offset;
      window.scrollTo({ top, behavior: 'smooth' });
    }
  };

  const filterCards = () => {
    const cards = document.querySelectorAll<HTMLElement>('[data-card]');
    let visible = 0;
    cards.forEach(card => {
      const zones    = card.dataset.zones?.split(',').map(z => z.trim()) ?? [];
      const services = card.dataset.services?.split(',').map(s => s.trim()) ?? [];
      let matchesZone = false;
      if (activeZone === '') {
        matchesZone = true;
      } else if (activeZone === '__todo_rosario__') {
        matchesZone = zones.some(z => z === 'Todo Rosario' || z === 'Rosario' || ROSARIO_ZONES.has(z));
      } else {
        matchesZone = zones.includes(activeZone) || zones.includes('Todo Rosario');
      }
      const matchesService = activeService === '' || services.includes(activeService);
      const show = matchesZone && matchesService;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    updateCount(visible);
    scrollToGrid();
    const hasFilter = activeZone !== '' || activeService !== '';
    resetBtn.classList.toggle('hidden', !hasFilter);
    resetBtn.style.display = hasFilter ? 'inline-flex' : '';
    if (noResults) noResults.classList.toggle('hidden', visible > 0);
  };

  const setZone = (value: string, labelText: string) => {
    activeZone = value;
    zoneLabel.textContent = value === '' ? 'Zona' : labelText;
    zoneTrigger.classList.toggle('is-active', value !== '');
    zoneTodo.classList.toggle('selected', value === '__todo_rosario__');
    barrioOpts.forEach(b => b.classList.toggle('selected', b.dataset.value === value));
    filterCards();
    closeAll();
  };

  const setService = (value: string, labelText: string) => {
    activeService = value;
    serviceLabel.textContent = value === '' ? 'Servicio' : labelText;
    serviceTrigger.classList.toggle('is-active', value !== '');
    serviceOpts.forEach(o => o.classList.toggle('selected', o.dataset.value === value));
    filterCards();
    closeAll();
  };

  zoneTodo.addEventListener('click', () => setZone('__todo_rosario__', 'Todo Rosario'));
  barrioOpts.forEach(b => b.addEventListener('click', () => setZone(b.dataset.value!, b.dataset.value!)));
  zoneClear.addEventListener('click', () => setZone('', 'Zona'));

  serviceOpts.forEach(o => o.addEventListener('click', () => {
    const newVal = activeService === o.dataset.value ? '' : o.dataset.value!;
    setService(newVal, o.dataset.value!);
  }));
  serviceClear.addEventListener('click', () => setService('', 'Servicio'));

  resetBtn.addEventListener('click', () => {
    setZone('', 'Zona');
    setService('', 'Servicio');
  });
</script>
