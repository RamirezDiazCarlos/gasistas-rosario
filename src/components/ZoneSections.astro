---
import gasistas from '../data/gasistas.json';

type Gasista = typeof gasistas[number];

const rosarioGasistas = gasistas
  .filter(g => g.zones.includes('Rosario'))
  .sort((a, b) => (b.featured ? 1 : 0) - (a.featured ? 1 : 0));

const zoneMap = new Map<string, Gasista[]>();

for (const g of gasistas) {
  for (const zone of g.zones) {
    if (zone === 'Rosario') continue;
    if (!zoneMap.has(zone)) zoneMap.set(zone, []);
    zoneMap.get(zone)!.push(g);
  }
}

const zones = [...zoneMap.entries()].sort((a, b) => b[1].length - a[1].length);
const mainZones = zones.filter(([, g]) => g.length >= 2);
const otherZones = zones.filter(([, g]) => g.length === 1);

const ROSARIO_PREVIEW = 4;
const rosarioVisible = rosarioGasistas.slice(0, ROSARIO_PREVIEW);
const rosarioExtra = rosarioGasistas.length - ROSARIO_PREVIEW;
---

<section id="cobertura" class="relative py-16 sm:py-20 bg-warm-50 border-t border-warm-200/60 overflow-hidden">

  <div
    class="absolute inset-0 pointer-events-none opacity-40"
    aria-hidden="true"
    style="background-image: radial-gradient(circle, #c8b49a 1px, transparent 1px); background-size: 28px 28px;"
  />

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid lg:grid-cols-[1fr_2fr] gap-6 mb-12 scroll-reveal items-end">
      <div>
        <p class="text-[10px] font-semibold text-flame/70 uppercase tracking-[0.2em] mb-4">
          Cobertura geográfica
        </p>
        <h2 class="font-display font-800 text-dark text-4xl sm:text-5xl tracking-tight leading-[0.95]">
          Gasistas en el<br />Gran Rosario
        </h2>
      </div>
      <p class="text-warm-800/55 text-sm leading-relaxed max-w-md lg:pb-1">
        Profesionales matriculados en Rosario, Funes, Roldán y otras localidades del Gran Rosario. Matrícula vigente y contacto directo por WhatsApp.
      </p>
    </div>

    <!-- Rosario — zona principal, card full-width dark -->
    <div class="mb-6 scroll-reveal">
      <div class="relative overflow-hidden bg-dark rounded-2xl border border-flame/25 p-7 sm:p-9 shadow-[0_4px_32px_-8px_rgba(0,0,0,0.20)]">

        <div class="absolute inset-0 pointer-events-none opacity-[0.022]"
          style="background-image: url('data:image/svg+xml,%3Csvg viewBox%3D%220 0 256 256%22 xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cfilter id%3D%22noise%22%3E%3CfeTurbulence type%3D%22fractalNoise%22 baseFrequency%3D%220.9%22 numOctaves%3D%224%22 stitchTiles%3D%22stitch%22%2F%3E%3C%2Ffilter%3E%3Crect width%3D%22100%25%22 height%3D%22100%25%22 filter%3D%22url(%23noise)%22%2F%3E%3C%2Fsvg%3E'); background-size: 180px;"
          aria-hidden="true" />

        <div class="absolute top-0 left-6 right-6 h-[2px] bg-gradient-to-r from-flame via-flame/40 to-transparent rounded-b-sm" aria-hidden="true" />

        <div class="relative flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-5 flex-wrap">
              <h3 class="font-display font-700 text-white text-2xl sm:text-3xl leading-tight flex items-center gap-2.5">
                <img src="/gas-industry (1).png" alt="" class="w-7 h-7 sm:w-8 sm:h-8 invert opacity-50" aria-hidden="true" draggable="false" />
                Gasistas en Rosario
              </h3>
              <span class="inline-flex items-center gap-1 font-mono text-[10px] text-flame font-semibold bg-flame/[0.12] border border-flame/[0.25] px-2 py-0.5 rounded-full tabular-nums">
                {rosarioGasistas.length} matriculados
              </span>
            </div>

            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-2" role="list">
              {rosarioVisible.map(g => (
                <li>
                  <a
                    href={`/${g.slug}`}
                    class="flex items-center gap-2.5 text-[13px] text-white/45 hover:text-flame transition-colors duration-200 ease-[cubic-bezier(0.16,1,0.3,1)] group/link"
                  >
                    <span
                      class="w-1.5 h-1.5 rounded-full bg-flame/40 group-hover/link:bg-flame flex-shrink-0 transition-colors duration-200"
                      aria-hidden="true"
                    />
                    {g.name}
                  </a>
                </li>
              ))}
            </ul>

            {rosarioExtra > 0 && (
              <p class="mt-4 text-[11px] text-white/20 font-mono">
                + {rosarioExtra} más
              </p>
            )}
          </div>

          <span class="hidden sm:block font-display font-800 leading-none select-none pointer-events-none tabular-nums text-flame/[0.12] flex-shrink-0 self-end"
            style="font-size: clamp(72px, 9vw, 110px); line-height: 1;"
            aria-hidden="true"
          >
            {rosarioGasistas.length}
          </span>
        </div>

      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-4 stagger-children">
      {mainZones.map(([zone, zoneGasistas]) => (
        <div class="group relative overflow-hidden bg-white rounded-xl border border-warm-200/60 p-4 transition-all duration-[400ms] ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-0.5 hover:border-warm-300/70 hover:shadow-[0_4px_16px_-4px_rgba(0,0,0,0.08)]">

          <div class="absolute top-0 left-4 right-4 h-[1.5px] bg-gradient-to-r from-flame/40 to-transparent rounded-b-sm" aria-hidden="true" />

          <div class="relative">
            <div class="flex items-baseline justify-between gap-2 mb-3">
              <h3 class="font-display font-700 text-dark text-base leading-tight flex items-center gap-1.5">
                <img src="/gas-industry (1).png" alt="" class="w-4 h-4 opacity-30" aria-hidden="true" draggable="false" />
                Gasistas en {zone}
              </h3>
              <span class="font-mono text-[10px] text-flame/65 font-semibold flex-shrink-0 tabular-nums">
                {zoneGasistas.length} mat.
              </span>
            </div>

            <ul class="flex flex-col gap-1.5" role="list">
              {zoneGasistas.slice(0, 3).map(g => (
                <li>
                  <a
                    href={`/${g.slug}`}
                    class="flex items-center gap-2 text-[12px] text-warm-800/60 hover:text-flame transition-colors duration-200 ease-[cubic-bezier(0.16,1,0.3,1)] group/link"
                  >
                    <span
                      class="w-1 h-1 rounded-full bg-warm-300 group-hover/link:bg-flame flex-shrink-0 transition-colors duration-200"
                      aria-hidden="true"
                    />
                    {g.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>

        </div>
      ))}
    </div>

    {otherZones.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {otherZones.map(([zone, zoneGasistas]) => (
          <a
            href={`/${zoneGasistas[0].slug}`}
            class="group inline-flex items-center gap-2 bg-white border border-warm-200/60 hover:border-flame/25 hover:bg-flame/[0.04] px-3.5 py-2 rounded-xl text-[12px] transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-px shadow-[0_1px_3px_rgba(0,0,0,0.04)]"
            title={`${zoneGasistas[0].name} — gasista matriculado en ${zone}`}
          >
            <svg width="9" height="9" viewBox="0 0 10 10" fill="none" class="text-flame/50 flex-shrink-0 group-hover:text-flame/80 transition-colors duration-200" aria-hidden="true">
              <path d="M5 1C3.619 1 2.5 2.119 2.5 3.5C2.5 5.5 5 9 5 9C5 9 7.5 5.5 7.5 3.5C7.5 2.119 6.381 1 5 1Z" stroke="currentColor" stroke-width="1.2"/>
              <circle cx="5" cy="3.5" r="1" fill="currentColor"/>
            </svg>
            <span class="font-semibold text-dark group-hover:text-flame transition-colors duration-200">{zone}</span>
            <span class="text-warm-800/40 group-hover:text-warm-800/60 transition-colors duration-200">{zoneGasistas[0].name}</span>
          </a>
        ))}
      </div>
    )}

  </div>
</section>
