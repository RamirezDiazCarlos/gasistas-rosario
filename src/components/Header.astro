---
---
<header class="sticky top-0 z-50 pointer-events-none">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-4 pb-1 pointer-events-auto relative z-50">
    <nav
      class="flex items-center justify-between bg-dark/90 backdrop-blur-2xl border border-white/[0.08] rounded-2xl px-4 sm:px-5 py-2.5 shadow-[0_8px_40px_rgba(0,0,0,0.5),0_0_0_1px_rgba(255,255,255,0.03)]"
      aria-label="Navegación principal"
    >
      <a href="/" class="flex items-center gap-2.5 group" aria-label="GasistasRosario - inicio">
        <div class="w-8 h-8 rounded-xl bg-flame/90 group-hover:bg-flame flex items-center justify-center flex-shrink-0 transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:scale-105 shadow-[0_2px_8px_rgba(224,116,24,0.4)]">
          <svg width="16" height="16" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M9 2C9 2 5 6.5 5 10.5C5 12.985 6.79 15 9 15C11.21 15 13 12.985 13 10.5C13 6.5 9 2 9 2Z" fill="white" opacity="0.9"/>
            <path d="M9 8C9 8 7.5 9.8 7.5 11.2C7.5 12.19 8.172 13 9 13C9.828 13 10.5 12.19 10.5 11.2C10.5 9.8 9 8 9 8Z" fill="#fef3c7"/>
          </svg>
        </div>
        <span class="font-display font-700 text-white text-[15px] tracking-tight leading-none">
          Gasistas<span class="text-flame">Rosario</span>
        </span>
      </a>

      <div class="hidden md:flex items-center gap-1">
        {[
          { href: "/#profesionales", label: "Profesionales" },
          { href: "/#como-funciona", label: "Cómo funciona" },
          { href: "/#listar", label: "Para gasistas" },
        ].map(({ href, label }) => (
          <a
            href={href}
            class="text-white/50 hover:text-white/90 text-[13px] font-medium px-3 py-1.5 rounded-lg transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] hover:bg-white/[0.07]"
          >
            {label}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-2">
        <a
          href="/#listar"
          class="group hidden sm:inline-flex items-center gap-2 bg-flame/90 hover:bg-flame text-white text-[13px] font-semibold pl-4 pr-1.5 py-1.5 rounded-full transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] shadow-[0_2px_12px_rgba(224,116,24,0.35)] hover:shadow-[0_4px_20px_rgba(224,116,24,0.45)] active:scale-[0.97]"
        >
          Publicá tu perfil
          <span class="w-6 h-6 rounded-full bg-black/20 flex items-center justify-center transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:translate-x-0.5 group-hover:-translate-y-px">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <path d="M2 8L8 2M8 2H4M8 2V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>

        <button
          id="mobile-menu-btn"
          class="md:hidden relative w-8 h-8 flex flex-col items-center justify-center gap-[5px] rounded-lg hover:bg-white/10 transition-colors duration-200"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="menu-bar block w-[18px] h-[1.5px] bg-white/80 rounded-full transition-all duration-400 ease-[cubic-bezier(0.32,0.72,0,1)] origin-center"></span>
          <span class="menu-bar block w-[18px] h-[1.5px] bg-white/80 rounded-full transition-all duration-400 ease-[cubic-bezier(0.32,0.72,0,1)]"></span>
        </button>
      </div>
    </nav>
  </div>

  <div
    id="mobile-menu"
    class="hidden fixed inset-0 top-0 z-40 pointer-events-auto bg-dark/95 backdrop-blur-3xl md:hidden flex-col justify-center items-center"
    role="navigation"
    aria-label="Menú móvil"
  >
    <div class="flex flex-col items-center gap-2 mt-20">
      {[
        { href: "/#profesionales", label: "Profesionales" },
        { href: "/#como-funciona", label: "Cómo funciona" },
        { href: "/#listar", label: "Para gasistas" },
      ].map(({ href, label }, i) => (
        <a
          href={href}
          class={`mobile-link text-white/70 hover:text-white text-2xl font-display font-600 px-8 py-3 rounded-2xl hover:bg-white/5 transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] translate-y-6 opacity-0`}
          style={`transition-delay: ${i * 60 + 80}ms`}
        >
          {label}
        </a>
      ))}
      <a
        href="/#listar"
        class="mobile-link mt-4 inline-flex items-center gap-2 bg-flame text-white font-semibold px-8 py-3.5 rounded-full translate-y-6 opacity-0 transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]"
        style="transition-delay: 260ms"
      >
        Publicá tu perfil
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const bars = document.querySelectorAll<HTMLElement>('.menu-bar');
  const mobileLinks = document.querySelectorAll<HTMLElement>('.mobile-link');
  let isOpen = false;

  btn?.addEventListener('click', () => {
    isOpen = !isOpen;
    btn.setAttribute('aria-expanded', String(isOpen));

    if (isOpen) {
      menu?.classList.remove('hidden');
      menu?.classList.add('flex');
      document.body.style.overflow = 'hidden';
      // Morph to X
      bars[0].style.cssText = 'transform: translateY(6.5px) rotate(45deg)';
      bars[1].style.cssText = 'transform: translateY(-6.5px) rotate(-45deg)';
      // Stagger links in
      requestAnimationFrame(() => {
        mobileLinks.forEach(link => {
          link.style.transform = 'translateY(0)';
          link.style.opacity = '1';
        });
      });
    } else {
      // Collapse
      bars[0].style.cssText = '';
      bars[1].style.cssText = '';
      mobileLinks.forEach(link => {
        link.style.transform = 'translateY(24px)';
        link.style.opacity = '0';
      });
      setTimeout(() => {
        menu?.classList.add('hidden');
        menu?.classList.remove('flex');
        document.body.style.overflow = '';
      }, 300);
    }
  });

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      if (!isOpen) return;
      isOpen = false;
      btn?.setAttribute('aria-expanded', 'false');
      bars[0].style.cssText = '';
      bars[1].style.cssText = '';
      mobileLinks.forEach(l => {
        (l as HTMLElement).style.transform = 'translateY(24px)';
        (l as HTMLElement).style.opacity = '0';
      });
      setTimeout(() => {
        menu?.classList.add('hidden');
        menu?.classList.remove('flex');
        document.body.style.overflow = '';
      }, 300);
    });
  });
</script>
