---
interface Gasista {
  id: string;
  slug: string;
  name: string;
  photo: string;
  matricula: string;
  zones: string[];
  services: string[];
  phone: string;
  rating: number;
  reviews: number;
  featured: boolean;
  description: string;
}

interface Props {
  gasista: Gasista;
}

import AvatarPlaceholder from './AvatarPlaceholder.astro';

const { gasista } = Astro.props;

const waLink = gasista.phone ? `https://wa.me/${gasista.phone}` : null;
const profileLink = `/${gasista.slug}`;

const fullStars = Math.floor(gasista.rating);
const hasHalf = gasista.rating % 1 >= 0.5;
const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "ProfessionalService"],
  "@id": `https://gasistasrosario.com.ar/${gasista.slug}#business`,
  "name": `${gasista.name} — Gasista Matriculado`,
  "description": gasista.description,
  "telephone": `+${gasista.phone}`,
  "priceRange": "$$",
  "areaServed": gasista.zones.map((z: string) => ({ "@type": "Place", "name": `${z}, Rosario, Santa Fe, Argentina` })),
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Rosario",
    "addressRegion": "Santa Fe",
    "addressCountry": "AR"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": gasista.rating,
    "reviewCount": gasista.reviews,
    "bestRating": 5,
    "worstRating": 1
  },
  "additionalProperty": {
    "@type": "PropertyValue",
    "name": "Matrícula ENARGAS",
    "value": gasista.matricula
  },
  "url": `https://gasistasrosario.com.ar/${gasista.slug}`
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

<div
  class:list={[
    "group h-full p-[5px] rounded-[1.5rem] transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]",
    gasista.featured
      ? "bg-gradient-to-b from-flame/[0.18] to-flame/[0.05] border border-flame/[0.28] shadow-[0_2px_24px_-4px_rgba(224,116,24,0.18)] hover:shadow-[0_8px_40px_-8px_rgba(224,116,24,0.28)]"
      : "bg-gradient-to-b from-warm-100/80 to-warm-50/60 border border-warm-200/80 shadow-[0_1px_8px_-2px_rgba(0,0,0,0.05),0_4px_16px_-8px_rgba(0,0,0,0.07)] hover:shadow-[0_4px_32px_-8px_rgba(0,0,0,0.12)]"
  ]}
>
  <article
    class="h-full bg-white rounded-[calc(1.5rem-5px)] overflow-hidden flex shadow-[inset_0_1px_0_rgba(255,255,255,0.9)]"
    aria-label={`Perfil de ${gasista.name}`}
  >

    <div class="relative flex-shrink-0 w-28 sm:w-32">
      {gasista.featured && (
        <div class="absolute top-2.5 left-2.5 z-10">
          <span class="inline-flex items-center gap-1 bg-flame text-white text-[10px] font-700 font-display px-2 py-1 rounded-full shadow-md shadow-flame/30 uppercase tracking-wider">
            <svg width="8" height="8" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <path d="M5 1L6.2 3.6L9 4L7 5.9L7.5 8.6L5 7.3L2.5 8.6L3 5.9L1 4L3.8 3.6L5 1Z" fill="currentColor"/>
            </svg>
            Top
          </span>
        </div>
      )}
      <a href={profileLink} tabindex="-1" aria-hidden="true" class="block h-full transition-transform duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:scale-105">
        <AvatarPlaceholder name={gasista.name} />
      </a>
      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-transparent to-black/[0.04] pointer-events-none"></div>
    </div>

    <div class="flex flex-col flex-1 p-4 sm:p-5 min-w-0">

      <div class="flex items-center justify-between gap-2 mb-3">
        <span class="inline-flex items-center gap-1.5 text-[10px] font-mono font-600 text-warm-800 bg-warm-50 border border-warm-200/70 px-2.5 py-1 rounded-lg tracking-wide shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
          <svg width="9" height="9" viewBox="0 0 9 9" fill="none" aria-hidden="true" class="opacity-50">
            <rect x="0.75" y="0.75" width="7.5" height="7.5" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
            <path d="M2.5 4.5H6.5M2.5 3H6.5M2.5 6H5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
          </svg>
          {gasista.matricula}
        </span>
        <a
          href={profileLink}
          class="flex-shrink-0 w-6 h-6 rounded-full bg-warm-100 hover:bg-flame hover:text-white text-warm-800 flex items-center justify-center transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] hover:scale-105"
          aria-label={`Ver perfil de ${gasista.name}`}
        >
          <svg width="9" height="9" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <path d="M2 8L8 2M8 2H4M8 2V6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <h3 class="font-display font-700 text-dark text-base sm:text-[17px] leading-tight mb-2 truncate">
        <a
          href={profileLink}
          class="hover:text-flame transition-colors duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] focus-visible:outline-none focus-visible:text-flame"
        >
          {gasista.name}
        </a>
      </h3>

      <p class="text-[11px] text-warm-800 leading-relaxed truncate mb-2.5 flex items-center gap-1.5">
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="flex-shrink-0 opacity-60" aria-hidden="true">
          <path d="M5 1C3.619 1 2.5 2.119 2.5 3.5C2.5 5.5 5 9 5 9C5 9 7.5 5.5 7.5 3.5C7.5 2.119 6.381 1 5 1Z" stroke="currentColor" stroke-width="1.2"/>
          <circle cx="5" cy="3.5" r="1" fill="currentColor"/>
        </svg>
        <span class="truncate">{gasista.zones.join(' · ')}</span>
      </p>

      <div class="flex flex-wrap gap-1 mb-3.5">
        {gasista.services.slice(0, 3).map((s: string) => (
          <span class="text-[10px] font-medium text-warm-900/70 bg-warm-50 border border-warm-200/60 px-2 py-0.5 rounded-md leading-relaxed">
            {s}
          </span>
        ))}
        {gasista.services.length > 3 && (
          <span class="text-[10px] font-medium text-warm-800/50 bg-warm-100 border border-warm-200/60 px-2 py-0.5 rounded-md leading-relaxed">
            +{gasista.services.length - 3}
          </span>
        )}
      </div>

      <div class="flex items-center justify-between gap-2 mt-auto flex-wrap">

        <span class="inline-flex items-center gap-1.5 text-[10px] font-medium text-warm-700 bg-warm-50 border border-warm-200/70 px-2 py-1 rounded-lg">
          <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="text-flame/70 flex-shrink-0">
            <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M4 6L5.5 7.5L8 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Matrícula verificada
        </span>

        {waLink ? (
          <a
            href={waLink}
            target="_blank"
            rel="noopener noreferrer"
            class="group/wa inline-flex items-center gap-1.5 pl-3 pr-1.5 py-1.5 bg-[#25D366] hover:bg-[#1ebe5d] text-white text-[12px] font-semibold rounded-full transition-all duration-400 ease-[cubic-bezier(0.32,0.72,0,1)] shadow-[0_2px_8px_rgba(37,211,102,0.25)] hover:shadow-[0_4px_16px_rgba(37,211,102,0.4)] active:scale-[0.97]"
            aria-label={`Contactar a ${gasista.name} por WhatsApp`}
          >
            WhatsApp
            <span class="w-6 h-6 rounded-full bg-black/15 flex items-center justify-center transition-transform duration-400 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover/wa:translate-x-px group-hover/wa:-translate-y-px">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.978-1.406A9.953 9.953 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a7.952 7.952 0 01-4.078-1.123l-.292-.174-3.027.854.856-3.03-.19-.31A7.96 7.96 0 014 12c0-4.418 3.582-8 8-8s8 3.582 8 8-3.582 8-8 8z"/>
              </svg>
            </span>
          </a>
        ) : (
          <span class="inline-flex items-center pl-3 pr-1.5 py-1.5 text-[12px] text-warm-800/40 italic rounded-full border border-warm-200/60 bg-warm-50">
            Próximamente
            <span class="w-6 h-6 ml-1.5 rounded-full bg-warm-100 inline-flex items-center justify-center flex-shrink-0"></span>
          </span>
        )}
      </div>

    </div>
  </article>
</div>
