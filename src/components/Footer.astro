---
const year = new Date().getFullYear();
---

<footer class="bg-dark border-t border-white/5">

  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-[1fr_auto_auto] gap-8 sm:gap-12">

      <!-- Brand column -->
      <div class="max-w-xs">
        <a href="/" class="inline-flex items-center gap-2.5 mb-4 group" aria-label="GasistasRosario - inicio">
          <div class="w-7 h-7 rounded-lg bg-flame flex items-center justify-center flex-shrink-0">
            <svg width="15" height="15" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M9 2C9 2 5 6.5 5 10.5C5 12.985 6.79 15 9 15C11.21 15 13 12.985 13 10.5C13 6.5 9 2 9 2Z" fill="white"/>
              <path d="M9 8C9 8 7.5 9.8 7.5 11.2C7.5 12.19 8.172 13 9 13C9.828 13 10.5 12.19 10.5 11.2C10.5 9.8 9 8 9 8Z" fill="#f59e0b"/>
            </svg>
          </div>
          <span class="font-display font-700 text-white text-base">
            Gasistas<span class="text-flame">Rosario</span>
          </span>
        </a>
        <p class="text-white/40 text-sm leading-relaxed">
          Directorio de gasistas matriculados en Rosario, Santa Fe. Conectamos vecinos con profesionales habilitados.
        </p>
      </div>

      <!-- Links column 1 -->
      <div>
        <h4 class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-4">Directorio</h4>
        <ul class="flex flex-col gap-2.5" role="list">
          <li><a href="/#profesionales" class="text-sm text-white/55 hover:text-white transition-colors">Profesionales</a></li>
          <li><a href="/#como-funciona" class="text-sm text-white/55 hover:text-white transition-colors">Cómo funciona</a></li>
          <li><a href="/#listar" class="text-sm text-white/55 hover:text-white transition-colors">Publicar perfil</a></li>
        </ul>
      </div>

      <!-- Links column 2 -->
      <div>
        <h4 class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-4">Información</h4>
        <ul class="flex flex-col gap-2.5" role="list">
          <li>
            <a
              href="https://www.litoral-gas.com.ar/site/hogares-y-comercios/info-y-tramites/listado-de-gasistas-y-profesionales/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-white/55 hover:text-white transition-colors inline-flex items-center gap-1.5"
            >
              Litoral Gas
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M2 8L8 2M8 2H4M8 2V6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
          <li><a href="/#listar" class="text-sm text-white/55 hover:text-white transition-colors">Contacto</a></li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 sm:gap-6">
        <p class="text-xs text-white/30">
          &copy; {year} GasistasRosario. Todos los derechos reservados.
        </p>
        <p class="text-xs text-white/25 sm:ml-auto">
          Desarrollado por <a href="https://www.kerneldev.com.ar/" target="_blank" rel="noopener noreferrer" class="text-white/40 hover:text-white/70 transition-colors">KERNEL</a>
        </p>
        <p class="text-xs text-white/20 sm:ml-auto max-w-lg">
          <strong class="text-white/30">Aviso:</strong> GasistasRosario es un directorio informativo. No controlamos la validez vigente de las matrículas en tiempo real. Antes de contratar, verificá la habilitación del profesional en el listado oficial de Litoral Gas.
          Los perfiles actualmente publicados son de presentación. El sitio está en proceso de incorporar profesionales reales.
        </p>
      </div>
    </div>
  </div>

</footer>
